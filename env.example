# Copy to .env before first run:  cp env.example .env

# fast     = no Ollama (instant, copies/trims changelog text)
# hybrid   = Ollama only when a NEW patch is detected (recommended)
# ai       = Ollama for every platform every run (slowest)
SUMMARY_MODE=hybrid

OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.2:1b
OLLAMA_NUM_PREDICT=260
OLLAMA_TIMEOUT_MS=300000
OLLAMA_RETRIES=3
OLLAMA_COOLDOWN_MS=3000
SUMMARY_EXCERPT_CHARS=1600
SCRAPE_CONCURRENCY=2

CRON_SCHEDULE=0 8 * * *

DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/1506484927498027061/mNvwSYdy5UccK_nYRE6uK5_XCtecXAyReUc0F3_hzfSlomfNKG3WCieirM5tIyWjNbFq

WEBHOOK_NOTIFY_ON=always

UI_PORT=3000
LOGS_DIR=./logs
