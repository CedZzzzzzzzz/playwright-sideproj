# Ollama config
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3

# Schedule (cron syntax) — default: every day at 8am
CRON_SCHEDULE=* * * * *

# Optional: Discord or Slack webhook URL for notifications
WEBHOOK_URL=

# Optional: only alert on this significance level and above (low | medium | high)
MIN_SIGNIFICANCE=low
